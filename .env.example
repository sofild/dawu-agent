# =============================================================================
# Dawu Agent - Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# Deployment Environment
# ---------------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Default LLM Configuration (primary model)
# ---------------------------------------------------------------------------
# Unified model config: works with any OpenAI-compatible API
MODEL_API_KEY=your_api_key_here
MODEL_BASE_URL=https://api.anthropic.com/v1
MODEL_NAME=claude-3-5-sonnet-20241022
MODEL_API_TYPE=anthropic

# Generation parameters
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# Fallback LLM Configuration (used when primary fails)
# ---------------------------------------------------------------------------
FALLBACK_MODEL_API_KEY=your_fallback_api_key_here
FALLBACK_MODEL_BASE_URL=https://api.openai.com/v1
FALLBACK_MODEL_NAME=gpt-4o
FALLBACK_MODEL_API_TYPE=openai

# ---------------------------------------------------------------------------
# Multi-Model Profiles (optional, for scenario-based routing)
# Format: PROFILE_NAME__<FIELD>=value
# Use double underscore to separate profile name from field
# ---------------------------------------------------------------------------
# Fast & cheap model for simple tasks
FAST__MODEL_API_KEY=your_fast_api_key_here
FAST__MODEL_BASE_URL=https://api.openai.com/v1
FAST__MODEL_NAME=gpt-4o-mini
FAST__MODEL_API_TYPE=openai

# Powerful model for complex reasoning
POWER__MODEL_API_KEY=your_power_api_key_here
POWER__MODEL_BASE_URL=https://api.anthropic.com/v1
POWER__MODEL_NAME=claude-3-opus-20240229
POWER__MODEL_API_TYPE=anthropic

# Vision-capable model for image analysis
VISION__MODEL_API_KEY=your_vision_api_key_here
VISION__MODEL_BASE_URL=https://api.openai.com/v1
VISION__MODEL_NAME=gpt-4o
VISION__MODEL_API_TYPE=openai

# Local model for privacy-sensitive tasks
LOCAL__MODEL_API_KEY=not-needed
LOCAL__MODEL_BASE_URL=http://localhost:11434/v1
LOCAL__MODEL_NAME=llama3.1
LOCAL__MODEL_API_TYPE=openai

# ---------------------------------------------------------------------------
# Legacy Provider Config (optional, for backward compatibility)
# If set, these override the unified config above
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# PostgreSQL (primary database for sessions, memory, audit logs)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dawu_agent

# Redis (caching, message broker, rate limiting)
REDIS_URL=redis://localhost:6379/0

# ChromaDB (vector database for semantic memory)
CHROMA_PERSIST_DIR=./memory/vector_db
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ---------------------------------------------------------------------------
# Observability & Monitoring
# ---------------------------------------------------------------------------
# OpenTelemetry OTLP endpoint (Jaeger, Tempo, or OTLP collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=dawu-agent
OTEL_SERVICE_VERSION=0.1.0

# Prometheus metrics port
PROMETHEUS_PORT=9090

# ---------------------------------------------------------------------------
# Security & Sandbox
# ---------------------------------------------------------------------------
# Encryption key for sensitive data at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Docker socket path (for sandbox container management)
DOCKER_SOCKET=unix:///var/run/docker.sock

# ---------------------------------------------------------------------------
# Web UI Configuration
# ---------------------------------------------------------------------------
# Password for the web UI login page (required by web_entry.py)
WEB_UI_PASSWORD=dawu-agent

# Optional: explicit secret for signing session cookies.
# If not set, a deterministic secret is derived from WEB_UI_PASSWORD.
# WEB_SESSION_SECRET=your_random_secret_here

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
# FastAPI server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# API authentication (optional, for server mode)
API_SECRET_KEY=your_api_secret_key_here

# ---------------------------------------------------------------------------
# MCP (Model Context Protocol) Settings
# ---------------------------------------------------------------------------
# MCP server command paths (comma-separated list of commands or URLs)
MCP_SERVERS=stdio:./mcp_servers/filesystem,stdio:./mcp_servers/sqlite

# ---------------------------------------------------------------------------
# Search Engine API Keys
# ---------------------------------------------------------------------------
# Baidu Qianfan AI Search API Key (for baidu_search tool)
# Get from: https://qianfan.baidu.com/
BAIDU_API_KEY=your_baidu_api_key_here

# Tavily AI Search API Key (for tavily_search tool)
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Enable/disable specific features
ENABLE_MULTI_AGENT=true
ENABLE_VECTOR_MEMORY=true
ENABLE_SANDBOX=true
ENABLE_AUDIT_LOG=true

# ---------------------------------------------------------------------------
# LiteLLM (transitive via DSPy)
# ---------------------------------------------------------------------------
# Skip LiteLLM's remote model-cost-map fetch on startup. The remote endpoint
# at raw.githubusercontent.com often times out from restricted networks and
# produces a noisy WARNING; the local backup cost map is sufficient.
LITELLM_LOCAL_MODEL_COST_MAP=True

# ---------------------------------------------------------------------------
# Agent guard rails
# ---------------------------------------------------------------------------
# Maximum tool calls allowed in a single LLM response. If the LLM exceeds
# this, the extra tool calls are dropped and a user reminder is injected to
# force synthesis. Prevents runaway tool-calling loops.
AGENT_MAX_TOOL_CALLS_PER_TURN=8

# Per-turn LLM call timeout (seconds). If the LLM takes longer the turn
# is treated as failed and retried with backoff.
AGENT_LLM_CALL_TIMEOUT_SECONDS=180

# DSPy fire-and-forget observation hook. Default OFF. When enabled, every
# turn fires an extra background LLM call to log what DSPy *would* have
# decided (useful for offline A/B and training data), but adds 30-40s/turn
# and can race with the main event loop. Leave OFF in production.
AGENT_DSPY_OBSERVE=false
